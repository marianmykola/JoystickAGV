<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/black">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PLC Settings"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="PLC IP Address"
        android:inputType="text"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etRack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Rack"
        android:inputType="number"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Slot"
        android:inputType="number"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDbNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="DB Number"
        android:inputType="number"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etOffset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Offset (bytes)"
        android:inputType="number"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Value (for write)"
        android:inputType="number"
        android:textColor="@android:color/white"
        android:textColorHint="@color/gray"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnRead"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Read"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnWrite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Write" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Response will appear here"
        android:textColor="@android:color/white"
        android:layout_marginTop="16dp" />

</LinearLayout>