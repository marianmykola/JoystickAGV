<!-- CONNECT -->
<ToggleButton
    android:id="@+id/btnStart"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textOn="CONNECTED"
    android:textOff="NOT CONNECTED"
    android:layout_marginTop="8dp"
    app:layout_constraintTop_toBottomOf="@id/txtValues"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

<!-- DMS -->
<ToggleButton
    android:id="@+id/btnDMS"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textOn="DMS ON"
    android:textOff="DMS OFF"
    android:layout_marginTop="8dp"
    app:layout_constraintTop_toBottomOf="@id/btnStart"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

<!-- ROTATE SWITCH -->
<RadioGroup
    android:id="@+id/rotateSwitch"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="8dp"
    app:layout_constraintTop_toBottomOf="@id/btnDMS"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <RadioButton android:id="@+id/rotate1" android:text="1" />
    <RadioButton android:id="@+id/rotate2" android:text="2" />
    <RadioButton android:id="@+id/rotate3" android:text="3" />
    <RadioButton android:id="@+id/rotate4" android:text="4" />
    <RadioButton android:id="@+id/rotate5" android:text="5" />
    <RadioButton android:id="@+id/rotate6" android:text="6" />
</RadioGroup>