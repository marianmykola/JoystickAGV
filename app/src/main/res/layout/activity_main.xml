<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- PLC SETTINGS BUTTON -->
    <Button
        android:id="@+id/btnPlcSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PLC"
        android:textColor="@android:color/white"
        android:background="@color/darker_gray"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VALUES TEXT -->
    <TextView
        android:id="@+id/txtValues"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L: 0,0 | R: 0,0"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtRotateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rotate"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnEstop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ROTATE SWITCH PICKER -->
    <NumberPicker
        android:id="@+id/rotatePicker"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@color/darker_gray"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtRotateLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CONNECT -->
    <ToggleButton
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textOn="CONNECTED"
        android:textOff="NOT CONNECTED"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtValues"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DMS -->
    <ToggleButton
        android:id="@+id/btnDMS"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textOn="DMS ON"
        android:textOff="DMS OFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ESTOP -->
    <ToggleButton
        android:id="@+id/btnEstop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textOn="ESTOP ON"
        android:textOff="ESTOP OFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnDMS"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ROTATE SWITCH PICKER -->
    <NumberPicker
        android:id="@+id/rotatePicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnEstop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- LEFT JOYSTICK -->
    <com.example.JoystickAGV.JoystickView
        android:id="@+id/joystickLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintWidth_percent="0.4"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RIGHT JOYSTICK -->
    <com.example.JoystickAGV.JoystickView
        android:id="@+id/joystickRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintWidth_percent="0.4"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>